    "@convex-dev/aggregate": "^0.1.23",
    "@convex-dev/migrations": "^0.2.9",
    "@convex-dev/polar": "catalog:",
    "@convex-dev/rate-limiter": "^0.2.12",
    "@convex-dev/resend": "^0.1.12",
    "@convex-dev/sharded-counter": "^0.1.8",
    "@fal-ai/client": "^1.6.2",
    "@openrouter/ai-sdk-provider": "^2.5.1",
    "@react-email/components": "^0.4.0",
    "@react-email/render": "^1.1.4",
    "@upstash/redis": "^1.35.3",
    "ai": "catalog:",
    "convex": "catalog:",
    "convex-env": "^2.5.0",
    "convex-helpers": "catalog:",
    "react": "catalog:react19",
    "svix": "^1.67.0",
    "uploadthing": "catalog:",
