{
  "name": "@acme/db",
  "private": true,
  "type": "module",
  "exports": {
    "./api": {
      "types": "./src/_generated/api.d.ts",
      "default": "./src/_generated/api.js"
    },
    "./model": {
      "types": "./src/_generated/dataModel.d.ts"
    },
    "./models": "./src/ai/models.ts",
    "./tools": "./src/ai/tools/index.ts",
    "./tools/search": "./src/ai/tools/search/index.ts",
    "./subscription": "./src/user/subscription.ts",
    "./library-types": "./src/types/library.ts"
  },
  "scripts": {
    "dev": "convex dev",
    "build": "convex deploy",
    "clean": "git clean -xdf .cache .turbo node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path .prettierignore",
    "fomat:fix": "prettier --write . --ignore-path ../../.gitignore --ignore-path .prettierignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "typecheck": "tsc --noEmit",
    "setup": "convex dev --until-success",
    "logs": "convex logs"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.88",
    "@ai-sdk/provider-utils": "^3.0.19",
    "@clerk/nextjs": "^6.25.4",
    "@convex-dev/agent": "0.3.2",
    "@convex-dev/aggregate": "^0.1.23",
    "@convex-dev/migrations": "^0.2.9",
    "@convex-dev/polar": "^0.5.0",
    "@convex-dev/rate-limiter": "^0.2.12",
    "@convex-dev/resend": "^0.1.12",
    "@convex-dev/sharded-counter": "^0.1.8",
    "@fal-ai/client": "^1.6.2",
    "@openrouter/ai-sdk-provider": "1.2.0",
    "@react-email/components": "^0.4.0",
    "@react-email/render": "^1.1.4",
    "@upstash/redis": "^1.35.3",
    "ai": "^5.0.116",
    "convex": "^1.26.2",
    "convex-env": "^2.5.0",
    "convex-helpers": "^0.1.104",
    "exa-js": "^1.8.23",
    "openai": "^5.12.2",
    "react": "^19.1.4",
    "svix": "^1.67.0",
    "uploadthing": "^7.7.3",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@acme/eslint-config": "workspace:*",
    "@convex-dev/eslint-plugin": "^1.1.1",
    "@types/node": "^20.19.0",
    "@types/react": "^19.1.6",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3"
  }
}
